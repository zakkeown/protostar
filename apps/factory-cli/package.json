{
  "name": "@protostar/factory-cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "protostar-factory": "./dist/main.js"
  },
  "exports": {
    "./pile-persistence": {
      "types": "./dist/pile-persistence.d.ts",
      "import": "./dist/pile-persistence.js"
    },
    "./refusals-index": {
      "types": "./dist/refusals-index.d.ts",
      "import": "./dist/refusals-index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "pnpm run build && node --test dist/*.test.js",
    "typecheck": "tsc -b --pretty false",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@protostar/artifacts": "workspace:*",
    "@protostar/authority": "workspace:*",
    "@protostar/delivery": "workspace:*",
    "@protostar/delivery-runtime": "workspace:*",
    "@protostar/dogpile-adapter": "workspace:*",
    "@protostar/dogpile-types": "workspace:*",
    "@protostar/evaluation": "workspace:*",
    "@protostar/execution": "workspace:*",
    "@protostar/intent": "workspace:*",
    "@protostar/lmstudio-adapter": "workspace:*",
    "@protostar/mechanical-checks": "workspace:*",
    "@protostar/paths": "workspace:*",
    "@protostar/planning": "workspace:*",
    "@protostar/policy": "workspace:*",
    "@protostar/repair": "workspace:*",
    "@protostar/repo": "workspace:*",
    "@protostar/review": "workspace:*"
  }
}
