{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@protostar/artifacts": ["packages/artifacts/src/index.ts"],
      "@protostar/delivery": ["packages/delivery/src/index.ts"],
      "@protostar/dogpile-adapter": ["packages/dogpile-adapter/src/index.ts"],
      "@protostar/evaluation": ["packages/evaluation/src/index.ts"],
      "@protostar/execution": ["packages/execution/src/index.ts"],
      "@protostar/intent": ["packages/intent/src/index.ts"],
      "@protostar/intent/acceptance-criteria": ["packages/intent/src/acceptance-criteria/index.ts"],
      "@protostar/intent/ambiguity": ["packages/intent/src/ambiguity/index.ts"],
      "@protostar/intent/clarification-report": ["packages/intent/src/clarification-report/index.ts"],
      "@protostar/intent/confirmed-intent": ["packages/intent/src/confirmed-intent/index.ts"],
      "@protostar/intent/draft": ["packages/intent/src/draft/index.ts"],
      "@protostar/planning": ["packages/planning/src/index.ts"],
      "@protostar/planning/artifacts": ["packages/planning/src/artifacts/index.ts"],
      "@protostar/planning/schema": ["packages/planning/src/schema/index.ts"],
      "@protostar/policy": ["packages/policy/src/index.ts"],
      "@protostar/policy/admission": ["packages/policy/src/admission/index.ts"],
      "@protostar/policy/archetypes": ["packages/policy/src/archetypes/index.ts"],
      "@protostar/policy/artifacts": ["packages/policy/src/artifacts/index.ts"],
      "@protostar/policy/capability-envelope": ["packages/policy/src/capability-envelope/index.ts"],
      "@protostar/repo": ["packages/repo/src/index.ts"],
      "@protostar/review": ["packages/review/src/index.ts"]
    }
  }
}
