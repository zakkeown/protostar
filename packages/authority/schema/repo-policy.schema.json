{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://protostar.local/schema/repo-policy.schema.json",
  "title": "RepoPolicy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "allowedScopes": { "type": "array", "items": { "type": "string" } },
    "repoScopes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["workspace", "path", "access"],
        "properties": {
          "workspace": { "type": "string" },
          "path": { "type": "string" },
          "access": { "enum": ["read", "write", "execute"] }
        }
      }
    },
    "toolPermissions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool"],
        "properties": {
          "tool": { "type": "string" },
          "permissionLevel": { "type": "string" }
        }
      }
    },
    "deniedTools": { "type": "array", "items": { "type": "string" } },
    "budgetCaps": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "maxUsd": { "type": "number", "minimum": 0 },
        "maxTokens": { "type": "number", "minimum": 0 },
        "timeoutMs": { "type": "number", "minimum": 0 },
        "maxRepairLoops": { "type": "number", "minimum": 0 }
      }
    },
    "trustOverride": { "enum": ["trusted", "untrusted"] }
  }
}
