{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://protostar.local/schema/precedence-decision.schema.json",
  "title": "PrecedenceDecision",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "status", "resolvedEnvelope", "tiers", "blockedBy"],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "status": { "enum": ["no-conflict", "resolved", "blocked-by-tier"] },
    "resolvedEnvelope": {
      "type": "object",
      "additionalProperties": true
    },
    "tiers": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tier", "envelope", "source"],
        "properties": {
          "tier": { "enum": ["confirmed-intent", "policy", "repo-policy", "operator-settings"] },
          "envelope": {
            "type": "object",
            "additionalProperties": true
          },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "blockedBy": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tier", "axis", "message"],
        "properties": {
          "tier": { "enum": ["confirmed-intent", "policy", "repo-policy", "operator-settings"] },
          "axis": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
