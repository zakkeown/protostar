{
  "name": "@protostar/lmstudio-adapter",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm run build && node --test dist/**/*.test.js",
    "typecheck": "tsc -p tsconfig.json --pretty false"
  },
  "dependencies": {
    "@protostar/execution": "workspace:*",
    "@protostar/intent": "workspace:*",
    "@protostar/authority": "workspace:*",
    "@protostar/repo": "workspace:*",
    "@protostar/artifacts": "workspace:*"
  },
  "sideEffects": false
}
