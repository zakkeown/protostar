{
  "name": "@protostar/lmstudio-adapter",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "pnpm run build && node --test dist/**/*.test.js",
    "typecheck": "tsc -p tsconfig.json --pretty false"
  },
  "dependencies": {
    "@protostar/execution": "workspace:*",
    "@protostar/intent": "workspace:*",
    "@protostar/authority": "workspace:*",
    "@protostar/repo": "workspace:*",
    "@protostar/artifacts": "workspace:*",
    "@protostar/review": "workspace:*",
    "diff": "9.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "protostar": {
    "tier": "network"
  },
  "engines": {
    "node": ">=22"
  }
}
