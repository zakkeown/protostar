{
  "name": "@protostar/intent",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./draft": {
      "types": "./dist/draft/index.d.ts",
      "import": "./dist/draft/index.js"
    },
    "./ambiguity": {
      "types": "./dist/ambiguity/index.d.ts",
      "import": "./dist/ambiguity/index.js"
    },
    "./acceptance-criteria": {
      "types": "./dist/acceptance-criteria/index.d.ts",
      "import": "./dist/acceptance-criteria/index.js"
    },
    "./clarification-report": {
      "types": "./dist/clarification-report/index.d.ts",
      "import": "./dist/clarification-report/index.js"
    },
    "./confirmed-intent": {
      "types": "./dist/confirmed-intent/index.d.ts",
      "import": "./dist/confirmed-intent/index.js"
    },
    "./admission": {
      "types": "./dist/admission/index.d.ts",
      "import": "./dist/admission/index.js"
    },
    "./internal/test-builders": {
      "types": "./dist/internal/test-builders.d.ts",
      "import": "./dist/internal/test-builders.js"
    },
    "./internal/brand-witness": {
      "types": "./dist/internal/brand-witness.d.ts",
      "import": "./dist/internal/brand-witness.js"
    },
    "./schema/clarification-report.schema.json": "./schema/clarification-report.schema.json",
    "./schema/confirmed-intent.schema.json": "./schema/confirmed-intent.schema.json",
    "./schema/intent-admission-decision.schema.json": "./schema/intent-admission-decision.schema.json",
    "./schema/capability-admission-decision.schema.json": "./schema/capability-admission-decision.schema.json",
    "./schema/repo-scope-admission-decision.schema.json": "./schema/repo-scope-admission-decision.schema.json"
  },
  "files": [
    "dist",
    "schema",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "test": "pnpm run build && node --test dist/*.test.js",
    "typecheck": "tsc -b --pretty false"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "protostar": {
    "tier": "pure"
  },
  "engines": {
    "node": ">=22"
  }
}
