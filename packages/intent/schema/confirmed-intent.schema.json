{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://protostar.local/schema/confirmed-intent.schema.json",
  "title": "ConfirmedIntent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "problem",
    "requester",
    "confirmedAt",
    "acceptanceCriteria",
    "capabilityEnvelope",
    "constraints",
    "stopConditions",
    "signature"
  ],
  "properties": {
    "schemaVersion": { "const": "1.5.0" },
    "id": { "type": "string", "pattern": "^intent_.+" },
    "sourceDraftId": { "type": "string", "pattern": "^draft_.+" },
    "mode": { "enum": ["greenfield", "brownfield"] },
    "goalArchetype": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "problem": { "type": "string", "minLength": 1 },
    "requester": { "type": "string", "minLength": 1 },
    "confirmedAt": { "type": "string" },
    "context": { "type": "string" },
    "acceptanceCriteria": { "type": "array" },
    "capabilityEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repoScopes", "workspace", "network", "budget", "toolPermissions"],
      "properties": {
        "repoScopes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["workspace", "path", "access"],
            "properties": {
              "workspace": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 },
              "access": { "enum": ["read", "write", "execute"] }
            }
          }
        },
        "workspace": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allowDirty"],
          "properties": {
            "allowDirty": { "type": "boolean" }
          }
        },
        "network": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allow"],
          "properties": {
            "allow": { "enum": ["none", "loopback", "allowlist"] },
            "allowedHosts": {
              "type": "array",
              "items": { "type": "string", "format": "hostname" },
              "minItems": 1
            }
          },
          "if": { "properties": { "allow": { "const": "allowlist" } } },
          "then": { "required": ["allowedHosts"] }
        },
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "required": ["adapterRetriesPerTask", "taskWallClockMs", "maxRepairLoops"],
          "properties": {
            "maxUsd": { "type": "number", "minimum": 0 },
            "maxTokens": { "type": "number", "minimum": 0 },
            "timeoutMs": { "type": "number", "minimum": 0 },
            "adapterRetriesPerTask": { "type": "integer", "minimum": 1, "maximum": 10, "default": 4 },
            "taskWallClockMs": { "type": "integer", "minimum": 1000, "maximum": 1800000, "default": 180000 },
            "deliveryWallClockMs": {
              "type": "integer",
              "minimum": 30000,
              "maximum": 3600000,
              "default": 600000
            },
            "maxRepairLoops": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "default": 3,
              "description": "Maximum review→repair→review iterations before block-with-evidence (Phase 5 LOOP-04)."
            }
          }
        },
        "toolPermissions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["tool", "reason", "risk"],
            "properties": {
              "tool": { "type": "string", "minLength": 1 },
              "permissionLevel": { "enum": ["read", "use", "write", "execute", "admin"] },
              "reason": { "type": "string", "minLength": 1 },
              "risk": { "enum": ["low", "medium", "high"] }
            }
          }
        },
        "executeGrants": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["command", "scope"],
            "properties": {
              "command": { "type": "string", "minLength": 1 },
              "scope": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 1 }
            }
          }
        },
        "delivery": {
          "type": "object",
          "additionalProperties": false,
          "required": ["target"],
          "properties": {
            "target": {
              "type": "object",
              "additionalProperties": false,
              "required": ["owner", "repo", "baseBranch"],
              "properties": {
                "owner": { "type": "string", "pattern": "^[a-zA-Z0-9](?:[a-zA-Z0-9-]{0,38}[a-zA-Z0-9])?$" },
                "repo": { "type": "string", "pattern": "^[a-zA-Z0-9._-]{1,100}$" },
                "baseBranch": { "type": "string", "pattern": "^[a-zA-Z0-9._/-]+$", "maxLength": 244 }
              }
            }
          }
        }
      }
    },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "stopConditions": { "type": "array", "items": { "type": "string" } },
    "signature": {
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/$defs/SignatureEnvelope" }
      ]
    }
  },
  "$defs": {
    "SignatureEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "canonicalForm",
        "value",
        "intentHash",
        "envelopeHash",
        "policySnapshotHash"
      ],
      "properties": {
        "algorithm": { "const": "sha256" },
        "canonicalForm": { "enum": ["json-c14n@1.0"] },
        "value": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "intentHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "envelopeHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "policySnapshotHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
