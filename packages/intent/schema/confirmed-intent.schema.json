{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://protostar.local/schema/confirmed-intent.schema.json",
  "title": "ConfirmedIntent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "id",
    "title",
    "problem",
    "requester",
    "confirmedAt",
    "acceptanceCriteria",
    "capabilityEnvelope",
    "constraints",
    "stopConditions",
    "signature"
  ],
  "properties": {
    "schemaVersion": { "const": "1.1.0" },
    "id": { "type": "string", "pattern": "^intent_.+" },
    "sourceDraftId": { "type": "string", "pattern": "^draft_.+" },
    "mode": { "enum": ["greenfield", "brownfield"] },
    "goalArchetype": { "type": "string" },
    "title": { "type": "string", "minLength": 1 },
    "problem": { "type": "string", "minLength": 1 },
    "requester": { "type": "string", "minLength": 1 },
    "confirmedAt": { "type": "string" },
    "context": { "type": "string" },
    "acceptanceCriteria": { "type": "array" },
    "capabilityEnvelope": { "type": "object" },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "stopConditions": { "type": "array", "items": { "type": "string" } },
    "signature": {
      "anyOf": [
        { "type": "null" },
        { "$ref": "#/$defs/SignatureEnvelope" }
      ]
    }
  },
  "$defs": {
    "SignatureEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "canonicalForm",
        "value",
        "intentHash",
        "envelopeHash",
        "policySnapshotHash"
      ],
      "properties": {
        "algorithm": { "const": "sha256" },
        "canonicalForm": { "enum": ["json-c14n@1.0"] },
        "value": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "intentHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "envelopeHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "policySnapshotHash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
