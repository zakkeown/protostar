{
  "name": "@protostar/policy",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./admission": {
      "types": "./dist/admission/index.d.ts",
      "import": "./dist/admission/index.js"
    },
    "./archetypes": {
      "types": "./dist/archetypes/index.d.ts",
      "import": "./dist/archetypes/index.js"
    },
    "./capability-envelope": {
      "types": "./dist/capability-envelope/index.d.ts",
      "import": "./dist/capability-envelope/index.js"
    },
    "./artifacts": {
      "types": "./dist/artifacts/index.d.ts",
      "import": "./dist/artifacts/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "pnpm run build && node --test dist/*.test.js",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@protostar/artifacts": "workspace:*",
    "@protostar/intent": "workspace:*"
  },
  "sideEffects": false
}
