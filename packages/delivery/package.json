{
  "name": "@protostar/delivery",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./authorization-payload": {
      "types": "./dist/authorization-payload.d.ts",
      "import": "./dist/authorization-payload.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "pnpm run build && node --test dist/**/*.test.js",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@protostar/artifacts": "workspace:*",
    "@protostar/intent": "workspace:*"
  },
  "sideEffects": false
}
