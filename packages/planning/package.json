{
  "name": "@protostar/planning",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./artifacts": {
      "types": "./dist/artifacts/index.d.ts",
      "import": "./dist/artifacts/index.js"
    },
    "./schema/no-plan-admitted.schema.json": "./schema/no-plan-admitted.schema.json"
  },
  "files": ["dist", "schema"],
  "scripts": {
    "build": "tsc -b",
    "test": "pnpm run build && node --test dist/*.test.js",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@protostar/intent": "workspace:*",
    "@protostar/policy": "workspace:*"
  },
  "sideEffects": false
}
