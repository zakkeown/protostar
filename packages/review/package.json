{
  "name": "@protostar/review",
  "version": "0.0.0",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "test": "pnpm run build && node --test dist/*.test.js",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@protostar/artifacts": "workspace:*",
    "@protostar/delivery": "workspace:*",
    "@protostar/dogpile-adapter": "workspace:*",
    "@protostar/dogpile-types": "workspace:*",
    "@protostar/execution": "workspace:*",
    "@protostar/intent": "workspace:*",
    "@protostar/planning": "workspace:*",
    "@protostar/repo": "workspace:*",
    "@protostar/repair": "workspace:*"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
